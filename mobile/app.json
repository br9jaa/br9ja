{
  "expo": {
    "name": "BR9ja Mobile",
    "slug": "br9ja-mobile",
    "scheme": "br9ja",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#010A1F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.br9ja.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#010A1F"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
